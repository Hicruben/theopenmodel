# Server/build-time secret only. Never rename this to NEXT_PUBLIC_* and never
# commit the real key. scripts/fetch-api-football.mjs also reads .env.local.
API_FOOTBALL_KEY=

# Full mode refreshes every UTC date in the lookahead and then standings. Live
# mode only refreshes today's fixtures plus the in-play endpoint, merging them
# into an existing full snapshot. Run full mode once before scheduling live.
API_FOOTBALL_REFRESH_MODE=full
API_FOOTBALL_LOOKAHEAD_DAYS=14
API_FOOTBALL_TIMEOUT_MS=15000
API_FOOTBALL_RETRIES=2
API_FOOTBALL_FAIL_ON_ERROR=false

# Optional output paths. Relative paths resolve from the process working
# directory; absolute paths let a server timer update the active static site.
API_FOOTBALL_DESTINATION=data/portal.json
API_FOOTBALL_PUBLIC_DESTINATION=public/data/portal-live.json

# Optional comma-separated API-Football league IDs. Empty keeps every league
# returned by the fixtures endpoints; filtering occurs after retrieval.
API_FOOTBALL_LEAGUE_IDS=

# Live fixtures and one standing table per discovered league/season are fetched
# separately. Lower the cap if a scheduled job must conserve the daily quota.
API_FOOTBALL_FETCH_LIVE=true
API_FOOTBALL_FETCH_STANDINGS=true
API_FOOTBALL_MAX_STANDING_TABLES=20

# Optional news output paths. A scheduled fetch can point the public destination
# at the active static site's data directory so headlines update without a build.
NEWS_DESTINATION=data/news.json
NEWS_PUBLIC_DESTINATION=public/data/news-live.json
NEWS_FAIL_ON_ERROR=false
